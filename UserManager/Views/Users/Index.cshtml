@model IEnumerable<UserManager.Models.User>

@{
    ViewData["Title"] = "Панель управления пользователями";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Админ-панель</h2>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-danger btn-sm">Выйти из системы</button>
        </form>
    </div>

    <div class="card bg-light mb-3 shadow-sm">
        <div class="card-body py-2 d-flex align-items-center gap-2">
            <button type="button" id="btnBlock" class="btn btn-warning btn-sm" title="Заблокировать">
                <i class="bi bi-lock-fill"></i> Заблокировать
            </button>

            <button type="button" id="btnUnblock" class="btn btn-success btn-sm" title="Разблокировать">
                <i class="bi bi-unlock-fill"></i> Разблокировать
            </button>

            <button type="button" id="btnDelete" class="btn btn-danger btn-sm" title="Удалить полностью">
                <i class="bi bi-trash-fill"></i> Удалить
            </button>

            <button type="button" id="btnDeleteUnverified" class="btn btn-outline-danger btn-sm" title="Удалить неподтвержденных">
                <i class="bi bi-person-x-fill"></i> Удалить неподтвержденных
            </button>
        </div>
    </div>

    <div class="table-responsive shadow border rounded">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 40px;" class="text-center">
                        <input type="checkbox" id="selectAll" class="form-check-input" />
                    </th>
                    <th>Имя</th>
                    <th>E-mail</th>
                    <th>Последний вход</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-center">
                            <input type="checkbox" name="userIds" value="@user.Id" class="form-check-input user-checkbox" />
                        </td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@(user.LastLogin.HasValue ? user.LastLogin.Value.ToLocalTime().ToString("g") : "Никогда")</td>
                        <td>
                            @if (user.Status == UserManager.Models.UserStatus.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (user.Status == UserManager.Models.UserStatus.Unverified)
                            {
                                <span class="badge bg-info text-dark">Unverified</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Blocked</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Логика чекбокса "Выбрать все"
        document.getElementById('selectAll').addEventListener('change', function () {
            const checkboxes = document.querySelectorAll('.user-checkbox');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

        // Функция для сбора ID всех выбранных пользователей
        function getSelectedIds() {
            const checkboxes = document.querySelectorAll('.user-checkbox:checked');
            const ids = Array.from(checkboxes).map(cb => parseInt(cb.value));
            return ids;
        }

        // Универсальная функция для отправки запросов на сервер
        async function sendAction(actionName) {
            const ids = getSelectedIds();

            if (ids.length === 0) {
                alert('Пожалуйста, выберите хотя бы одного пользователя!');
                return;
            }

            try {
                const response = await fetch(`/Users/${actionName}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(ids)
                });

                if (response.ok) {
                    // Перезагружаем страницу, чтобы увидеть обновленные статусы
                    window.location.reload();
                } else {
                    alert('Произошла ошибка при выполнении операции.');
                }
            } catch (error) {
                console.error('Ошибка:', error);
                alert('Не удалось связаться с сервером.');
            }
        }

        // 2. Привязываем клики по кнопкам тулбара к их экшенам на бэкенде
        document.getElementById('btnBlock').addEventListener('click', () => sendAction('Block'));
        document.getElementById('btnUnblock').addEventListener('click', () => sendAction('Unblock'));
        document.getElementById('btnDelete').addEventListener('click', () => {
            if (confirm('Вы уверены, что хотите полностью удалить выбранных пользователей?')) {
                sendAction('Delete');
            }
        });
        document.getElementById('btnDeleteUnverified').addEventListener('click', () => {
            if (confirm('Удалить только выбранных неподтвержденных пользователей?')) {
                sendAction('DeleteUnverified');
            }
        });
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}